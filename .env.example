# ── Database ───────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET="busybeds-super-secret-jwt-key-change-in-production"

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Stripe ─────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Leave blank in dev to use mock payments (free, no setup needed)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Email (SMTP) ───────────────────────────────────────────────
# For Gmail: enable 2FA then create an App Password at:
# https://myaccount.google.com/apppasswords
# Leave blank in dev — emails print to the console instead
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="Busy Beds <noreply@busybeds.com>"
