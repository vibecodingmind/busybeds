# ── Database ───────────────────────────────────────────────────
# For Railway: Set both to the same value (Railway DATABASE_URL)
# For Supabase/Neon: Use pooled connection for DATABASE_URL, direct for DIRECT_URL
DATABASE_URL="postgresql://user:password@host:5432/busybeds"
DIRECT_URL="postgresql://user:password@host:5432/busybeds"

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET="busybeds-super-secret-jwt-key-change-in-production"

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Stripe ─────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── PayPal ─────────────────────────────────────────────────────
# Get these from https://developer.paypal.com/dashboard/applications/live
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="live"   # sandbox | live

# ── Pesapal ────────────────────────────────────────────────────
# Get these from https://pay.pesapal.com/iframe/PesapalIframe3/Dashboard
PESAPAL_CONSUMER_KEY=""
PESAPAL_CONSUMER_SECRET=""
PESAPAL_MODE="live"   # sandbox | live
PESAPAL_IPN_URL="https://yourdomain.com/api/payments/pesapal/callback"

# ── Google OAuth (Login with Google) ───────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add Authorised redirect URI: https://yourdomain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://yourdomain.com/api/auth/google/callback"

# ── Google Maps ────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Enable "Maps Embed API" for your project
# 3. Create an API key → restrict it to Maps Embed API + your domain
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ── Google Places API (Hotel Import) ──────────────────────────
# Used by Admin → Hotels → Import from Google Places
# Requires "Places API" enabled on the same Google Cloud project.
# If not set separately, falls back to NEXT_PUBLIC_GOOGLE_MAPS_API_KEY.
# Keep this key server-side only (no NEXT_PUBLIC_ prefix) so it stays secret.
GOOGLE_PLACES_API_KEY=""

# ── Email (Resend) ─────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → Create API Key
# Add your sending domain at Resend → Domains, then verify DNS records
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="BusyBeds <noreply@yourdomain.com>"
