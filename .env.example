# ── Database ───────────────────────────────────────────────────
# For Railway: Set both to the same value (Railway DATABASE_URL)
# For Supabase/Neon: Use pooled connection for DATABASE_URL, direct for DIRECT_URL
DATABASE_URL="postgresql://user:password@host:5432/busybeds"
DIRECT_URL="postgresql://user:password@host:5432/busybeds"

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET="busybeds-super-secret-jwt-key-change-in-production"

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Stripe ─────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── PayPal ─────────────────────────────────────────────────────
# Get these from https://developer.paypal.com/dashboard/applications/live
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="live"   # sandbox | live

# ── Pesapal ────────────────────────────────────────────────────
# Get these from https://pay.pesapal.com/iframe/PesapalIframe3/Dashboard
PESAPAL_CONSUMER_KEY=""
PESAPAL_CONSUMER_SECRET=""
PESAPAL_MODE="live"   # sandbox | live
PESAPAL_IPN_URL="https://yourdomain.com/api/payments/pesapal/callback"

# ── Google OAuth (Login with Google) ───────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add Authorised redirect URI: https://yourdomain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://yourdomain.com/api/auth/google/callback"

# ── Google Maps ────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Enable "Maps Embed API" for your project
# 3. Create an API key → restrict it to Maps Embed API + your domain
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ── Google Places API (Hotel Import) ──────────────────────────
# Used by Admin → Hotels → Import from Google Places
# Requires "Places API" enabled on the same Google Cloud project.
# If not set separately, falls back to NEXT_PUBLIC_GOOGLE_MAPS_API_KEY.
# Keep this key server-side only (no NEXT_PUBLIC_ prefix) so it stays secret.
GOOGLE_PLACES_API_KEY=""

# ── Email (cPanel SMTP) ────────────────────────────────────────
# Use your cPanel email account credentials
# In cPanel → Email Accounts → Connect Devices to find these values
SMTP_HOST="mail.yourdomain.com"
SMTP_PORT="465"                          # 465 for SSL, 587 for TLS/STARTTLS
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="your-email-password"
EMAIL_FROM="BusyBeds <noreply@yourdomain.com>"

# ── SDASMS (SMS Notifications) ────────────────────────────────
# Sign up at https://my.sdasms.com → Developers → Get API Token
# Set SDASMS_SENDER_ID to your registered alphanumeric sender (max 11 chars)
# SMS is sent on: coupon generation, subscription activation, expiry reminders
SDASMS_API_TOKEN="1|your_api_token_here"
SDASMS_SENDER_ID="BusyBeds"

# ── Vercel Cron Jobs ──────────────────────────────────────────
# Used to authenticate cron requests from Vercel (GET requests with Authorization: Bearer <secret>)
# Generate a random string: openssl rand -hex 32
# Add this same value in your Vercel project environment variables.
CRON_SECRET="your-random-secret-here"

# ── Admin & Site ───────────────────────────────────────────────
# Email address that receives hotel ownership applications (/apply)
ADMIN_EMAIL="admin@yourdomain.com"
# Public site URL (used in emails, og tags etc) — same as NEXT_PUBLIC_APP_URL
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# ── Stripe Hotel Webhook ───────────────────────────────────────
# Separate webhook secret for hotel subscription payments
# Create at dashboard.stripe.com → Webhooks → Add endpoint → /api/webhooks/stripe-hotel
STRIPE_HOTEL_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"

# ── PayPal Webhook ─────────────────────────────────────────────
# Webhook ID from developer.paypal.com → My Apps → Webhooks
PAYPAL_WEBHOOK_ID="your_paypal_webhook_id"

# ── Web Push Notifications (VAPID) ────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is exposed to the browser (safe)
# VAPID_PRIVATE_KEY must stay server-side only
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your_vapid_public_key"
VAPID_PRIVATE_KEY="your_vapid_private_key"
