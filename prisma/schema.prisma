generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  passwordHash         String
  role                 String    @default("traveler")
  fullName             String
  phone                String?
  createdAt            DateTime  @default(now())
  suspendedAt          DateTime?
  suspendedReason      String?
  isBanned             Boolean   @default(false)

  // Email verification
  emailVerified        Boolean   @default(false)
  emailVerifyToken     String?
  emailVerifyExpiry    DateTime?
  googleId             String?   @unique

  // Avatar
  avatar               String?

  // Password reset
  passwordResetToken   String?
  passwordResetExpiry  DateTime?

  // Preferences
  language             String    @default("en")
  timezone             String    @default("UTC")

  // Relations
  subscriptions        Subscription[]
  coupons              Coupon[]          @relation("CouponOwner")
  redeemedCoupons      Coupon[]          @relation("CouponRedeemer")
  hotelOwner           HotelOwner?
  hotelManager         HotelManager?
  suggestions          HotelSuggestion[]
  reviews              Review[]
  favorites            Favorite[]
  referralCode         String?   @unique
  referralUseGiven     ReferralUse[] @relation("ReferralGiven")
  referralUseReceived  ReferralUse?  @relation("ReferralReceived")
  referralsMade        Referral[]    @relation("ReferralsMade")
  referralReceived     Referral[]    @relation("ReferralReceived")
  earningsGiven        ReferralEarning[] @relation("EarningsGiven")
  earningsReceived     ReferralEarning[] @relation("EarningsReceived")
  referralPayouts      ReferralPayout[]
  loyaltyPoints        LoyaltyPoints?
  giftCardsPurchased GiftCard[] @relation("GiftCardsPurchased")
  giftCardsRedeemed  GiftCard[] @relation("GiftCardsRedeemed")
  auditLogs        AuditLog[]
  pointTransactions PointTransaction[]
  notifications   Notification[]
  priceAlerts     PriceAlert[]
  pushSubscription PushSubscription?
  messagesSent     Message[] @relation("MessagesSent")
  messagesReceived Message[] @relation("MessagesReceived")
  notificationPreference NotificationPreference?
}

model HotelType {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String   @default("hotel")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Hotel {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  city             String
  country          String
  category         String    @default("Hotel")
  descriptionShort String
  descriptionLong  String
  starRating       Int       @default(3)
  amenities        String    @default("[]")
  vibeTags         String    @default("[]")
  discountRules    String    @default("[]")
  websiteUrl       String?
  status           String    @default("active")
  isFeatured       Boolean   @default(false)
  featuredUntil    DateTime?
  coverImage       String?   @default("https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt @default(now())
  discountPercent  Int       @default(15)
  couponValidDays  Int       @default(30)

  // Contact info
  email            String?
  whatsapp         String?
  address          String?

  // Social media
  socialFacebook   String?
  socialInstagram  String?
  socialTwitter    String?
  socialTiktok     String?

  // Analytics
  viewCount        Int       @default(0)
  lastCouponAt     DateTime?

  // Computed average (updated on review save)
  avgRating        Float?

  // Geo location
  latitude         Float?
  longitude        Float?
  reviewCount      Int       @default(0)
  googlePlaceId        String?   @unique

  // Relations
  owner            HotelOwner?
  managers         HotelManager[]
  roomTypes        RoomType[]
  photos           HotelPhoto[]
  coupons          Coupon[]
  affiliateLinks   AffiliateLink[]
  bookingCommissions BookingCommission[]
  reviews          Review[]
  favorites        Favorite[]
  priceAlerts      PriceAlert[]
  flashDeals       FlashDeal[]
}

model HotelOwner {
  id                 String    @id @default(cuid())
  userId             String    @unique
  hotelId            String    @unique
  kycStatus          String    @default("pending")
  kycDocuments       String?
  kycSubmittedAt     DateTime  @default(now())
  kycReviewedAt      DateTime?
  kycRejectionReason String?

  user               User      @relation(fields: [userId], references: [id])
  hotel              Hotel     @relation(fields: [hotelId], references: [id])
}

model HotelManager {
  id         String   @id @default(cuid())
  userId     String   @unique
  hotelId    String
  assignedBy String?
  assignedAt DateTime @default(now())
  isActive   Boolean  @default(true)

  user       User     @relation(fields: [userId], references: [id])
  hotel      Hotel    @relation(fields: [hotelId], references: [id])
}

model RoomType {
  id             String  @id @default(cuid())
  hotelId        String
  name           String
  description    String
  pricePerNight  Float
  currency       String  @default("USD")
  maxOccupancy   Int     @default(2)
  displayOrder   Int     @default(0)

  hotel          Hotel   @relation(fields: [hotelId], references: [id])
}

model HotelPhoto {
  id           String   @id @default(cuid())
  hotelId      String
  url          String
  isPrimary    Boolean  @default(false)
  displayOrder Int      @default(0)
  uploadedAt   DateTime @default(now())

  hotel        Hotel    @relation(fields: [hotelId], references: [id])
}

model SubscriptionPackage {
  id                   String   @id @default(cuid())
  name                 String
  priceMonthly         Float
  priceAnnual          Float?
  durationDays         Int
  couponLimitPerPeriod Int      @default(5)
  tier                 String   @default("basic")
  isActive             Boolean  @default(true)
  stripePriceIdMonthly String?
  paypalPlanId         String?
  createdAt            DateTime @default(now())

  subscriptions        Subscription[]
}

model Subscription {
  id           String    @id @default(cuid())
  userId       String
  packageId    String
  status       String    @default("active")
  billingCycle String    @default("monthly")
  startsAt     DateTime  @default(now())
  expiresAt    DateTime
  stripeSubId  String?
  compedBy     String?
  compedReason String?
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id])
  package      SubscriptionPackage @relation(fields: [packageId], references: [id])
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  customCode      String?   // optional custom code like "SUMMER20"
  qrDataUrl       String?
  userId          String
  hotelId         String
  subscriptionId  String
  discountPercent Int
  guestName       String?   // set when coupon is for a friend/guest
  status          String    @default("active")
  generatedAt     DateTime  @default(now())
  expiresAt       DateTime
  startTime       DateTime? // when coupon becomes valid (for time-window coupons)
  endTime         DateTime? // when coupon expires (use expiresAt as backup)
  usageLimit      Int?      // max times this coupon can be redeemed (null = unlimited)
  usageCount      Int       @default(0) // current redemptions
  redeemedAt      DateTime?
  redeemedBy      String?
  cancelledAt     DateTime?
  cancelledBy     String?

  user            User      @relation("CouponOwner", fields: [userId], references: [id])
  hotel           Hotel     @relation(fields: [hotelId], references: [id])
  redeemer        User?     @relation("CouponRedeemer", fields: [redeemedBy], references: [id])

  @@index([hotelId])
  @@index([status])
  @@index([expiresAt])
  @@index([startTime])
}

model Review {
  id          String   @id @default(cuid())
  hotelId     String
  userId      String
  rating      Int      // 1-5
  title       String
  body        String
  isVerified  Boolean  @default(false)
  isApproved  Boolean  @default(false)
  ownerReply  String?
  repliedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hotelId, userId])
}

model HotelSuggestion {
  id                String    @id @default(cuid())
  suggestedByUserId String?
  suggestedByEmail  String?
  hotelName         String
  hotelCity         String
  hotelCountry      String
  hotelWebsite      String?
  notes             String?
  status            String    @default("pending")
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())

  suggestedBy       User?     @relation(fields: [suggestedByUserId], references: [id])
}

model AffiliateLink {
  id        String   @id @default(cuid())
  hotelId   String
  platform  String
  url       String
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  hotel     Hotel    @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, platform])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  hotelId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  hotel     Hotel    @relation(fields: [hotelId], references: [id])

  @@unique([userId, hotelId])
}

model ReferralUse {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String   @unique
  createdAt    DateTime @default(now())

  referrer     User     @relation("ReferralGiven", fields: [referrerId], references: [id])
  referred     User     @relation("ReferralReceived", fields: [referredId], references: [id])
}

model Amenity {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String   @default("✓")
  category  String   @default("general")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id    String @id @default("global")
  key   String @unique
  value String
}

model NewsletterSubscriber {
  id            String   @id @default(cuid())
  email         String   @unique
  subscribedAt  DateTime @default(now())
  unsubscribedAt DateTime?
  updatedAt     DateTime @updatedAt
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String?
  code        String   @unique
  usedAt      DateTime?
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())
  referrer    User     @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referred    User?    @relation("ReferralReceived", fields: [referredId], references: [id], onDelete: SetNull)
}

model LoyaltyPoints {
  id          String   @id @default(cuid())
  userId      String   @unique
  points      Int      @default(0)
  lifetime    Int      @default(0)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PointTransaction {
  id          String   @id @default(cuid())
  userId      String
  points      Int
  type        String
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PromoBanner {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  ctaText     String   @default("Learn More")
  ctaUrl      String   @default("/")
  bgColor     String   @default("#FF385C")
  textColor   String   @default("#FFFFFF")
  isActive    Boolean  @default(true)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("system")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model GiftCard {
  id            String    @id @default(cuid())
  code          String    @unique
  amount        Float     // USD value
  balance       Float     // remaining balance
  purchasedById String?
  redeemedById  String?
  recipientEmail String?
  recipientName  String?
  message       String?
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  purchasedAt   DateTime  @default(now())
  redeemedAt    DateTime?
  updatedAt     DateTime  @updatedAt
  purchasedBy   User?     @relation("GiftCardsPurchased", fields: [purchasedById], references: [id], onDelete: SetNull)
  redeemedBy    User?     @relation("GiftCardsRedeemed", fields: [redeemedById], references: [id], onDelete: SetNull)
}

model PriceAlert {
  id          String   @id @default(cuid())
  hotelId     String
  email       String
  userId      String?
  minDiscount Int      @default(0)   // alert when discount >= this %
  isActive    Boolean  @default(true)
  lastAlertAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([hotelId, email])
  @@index([hotelId])
  @@index([email])
  @@index([isActive])
}

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String   @unique
  subscription String   // JSON string of PushSubscriptionJSON
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FlashDeal {
  id              String    @id @default(cuid())
  hotelId         String
  title           String
  discountPercent Int
  startsAt        DateTime
  endsAt          DateTime
  isActive        Boolean   @default(true)
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  hotel           Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([isActive])
  @@index([endsAt])
}

model AffiliateLinkClick {
  id          String   @id @default(cuid())
  hotelId     String
  platform    String
  userId      String?
  ipHash      String?
  clickedAt   DateTime @default(now())

  @@index([hotelId])
  @@index([platform])
  @@index([clickedAt])
}

model ReferralEarning {
  id             String   @id @default(cuid())
  referrerId     String
  referredId     String
  amount         Float
  status         String   @default("pending")
  subscriptionId String?
  createdAt      DateTime @default(now())
  availableAt    DateTime
  referrer       User     @relation("EarningsGiven",    fields: [referrerId], references: [id], onDelete: Cascade)
  referred       User     @relation("EarningsReceived", fields: [referredId],  references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([status])
}

model ReferralPayout {
  id          String    @id @default(cuid())
  userId      String
  amount      Float
  paypalEmail String
  status      String    @default("requested")
  adminNotes  String?
  requestedAt DateTime  @default(now())
  processedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ── New Models for Additional Features ────────────────────────────────────────

// Message System (Guest to Hotel communication)
model Message {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  hotelId     String
  subject     String
  body        String
  isRead      Boolean  @default(false)
  repliedAt   DateTime?
  reply       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sender      User     @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("MessagesReceived", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([senderId])
  @@index([recipientId])
}

// Booking Commission Tracking
model BookingCommission {
  id              String   @id @default(cuid())
  hotelId         String
  platform        String   // "booking.com", "agoda", "airbnb"
  commissionRate  Float    // e.g., 0.05 = 5%
  trackingUrl     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hotel           Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, platform])
  @@index([hotelId])
}

// Email Campaign Tracking
model EmailCampaign {
  id           String   @id @default(cuid())
  title        String
  content      String
  recipientCount Int   @default(0)
  openCount    Int     @default(0)
  clickCount   Int     @default(0)
  sentAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  trackingEvents EmailTrackingEvent[]

  @@index([sentAt])
}

model EmailTrackingEvent {
  id         String   @id @default(cuid())
  campaignId String
  userId     String?
  email      String
  eventType  String   // "open", "click", "bounce", "unsubscribe"
  trackingId String?
  createdAt  DateTime @default(now())

  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([email])
  @@index([eventType])
}

// SMS Tracking
model SMSLog {
  id        String   @id @default(cuid())
  userId    String?
  phone     String
  message   String
  provider  String   @default("twilio")
  status    String   @default("pending") // pending, sent, failed, delivered
  cost      Float?
  createdAt DateTime @default(now())
  sentAt    DateTime?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Notification Preferences
model NotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  emailNewDeals         Boolean  @default(true)
  emailWeeklyDigest     Boolean  @default(true)
  emailRedemptionReminder Boolean @default(true)
  pushNotifications     Boolean  @default(true)
  smsAlerts             Boolean  @default(false)
  language              String   @default("en")
  timezone              String   @default("UTC")
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Partner API Keys
model PartnerAPIKey {
  id              String   @id @default(cuid())
  partnerId       String
  keyPrefix       String   // "pk_live_..." or "pk_test_..."
  keyHash         String   @unique
  name            String
  rateLimit       Int      @default(1000)   // requests per day
  isActive        Boolean  @default(true)
  lastUsedAt      DateTime?
  createdAt       DateTime @default(now())
  expiresAt       DateTime?

  @@index([partnerId])
  @@index([isActive])
}

// Coupon Enhancement (add custom codes & limits)
// Note: Coupon model already has fields, just documenting what should be added:
// customCode String? - alphanumeric coupon code like "SUMMER20"
// usageLimit Int? - max times this coupon can be redeemed
// usageCount Int @default(0) - current redemptions
// startTime DateTime? - when coupon becomes valid (for time-based coupons)
// endTime DateTime? - when coupon expires (already have expiresAt)

// Analytics Event Tracking
model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventType String   // "view_hotel", "click_coupon", "redeem_coupon", "purchase_subscription"
  hotelId   String?
  couponId  String?
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([hotelId])
  @@index([createdAt])
}

// Bulk Upload Jobs
model BulkUploadJob {
  id        String   @id @default(cuid())
  uploadedBy String
  fileName  String
  totalRows Int
  processedRows Int @default(0)
  failedRows Int @default(0)
  status    String   @default("pending") // pending, processing, completed, failed
  errorLog  String?  // JSON array of errors
  startedAt DateTime?
  completedAt DateTime?
  createdAt DateTime @default(now())

  @@index([uploadedBy])
  @@index([status])
}
